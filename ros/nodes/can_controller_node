#!/usr/bin/env python
"""ROS node: read CAN 0x112 controller frames, calibrate, and publish HandJointState."""

import socket
import struct

import rospy

from umi_dex.can_protocol import (
    CanAssembler,
    CircularFilter,
    JOINT_NAMES,
    NUM_JOINTS,
)
from umi_dex.calibration import Calibrator
from umi_dex.msg import HandJointState


# ---------- low-level SocketCAN helpers ----------


def open_can_socket(channel: str) -> socket.socket:
    """Open a raw SocketCAN socket bound to *channel* (e.g. 'can0')."""
    sock = socket.socket(socket.AF_CAN, socket.SOCK_RAW, socket.CAN_RAW)
    sock.settimeout(0.1)
    sock.bind((channel,))
    return sock


CAN_FRAME_FMT = "=IB3x8s"  # can_id (4), dlc (1), pad (3), data (8)
CAN_FRAME_SIZE = struct.calcsize(CAN_FRAME_FMT)


def recv_can_frame(sock: socket.socket):
    """Receive one CAN frame.  Returns (arb_id, dlc, data) or None on timeout."""
    try:
        raw = sock.recv(CAN_FRAME_SIZE)
    except socket.timeout:
        return None
    if len(raw) < CAN_FRAME_SIZE:
        return None
    can_id, dlc, data = struct.unpack(CAN_FRAME_FMT, raw)
    arb_id = can_id & 0x1FFFFFFF
    return arb_id, dlc, data


# ---------- main ----------

def main():
    rospy.init_node("can_controller", anonymous=False)

    channel = rospy.get_param("~can_channel", "can0")
    calibration_csv = rospy.get_param("~calibration_csv", "")
    filter_alpha = rospy.get_param("~filter_alpha", 0.3)
    enable_filter = rospy.get_param("~enable_filter", True)

    calibrator = Calibrator(csv_path=calibration_csv) if calibration_csv else Calibrator()
    assembler = CanAssembler()

    filt = None
    if enable_filter:
        filt = CircularFilter(alpha=filter_alpha,
                              wrapped_channels=calibrator.wrapped_channels())

    pub = rospy.Publisher("/hand/joint_states", HandJointState, queue_size=10)

    rospy.loginfo("Opening SocketCAN on %s", channel)
    try:
        sock = open_can_socket(channel)
    except OSError as e:
        rospy.logfatal("Cannot open CAN socket on %s: %s", channel, e)
        return

    rospy.loginfo("CAN controller node started")
    while not rospy.is_shutdown():
        result = recv_can_frame(sock)
        if result is None:
            continue

        arb_id, dlc, data = result
        assembled = assembler.feed(arb_id, dlc, data)
        if assembled is None:
            continue

        raw_counts, valid_mask = assembled

        if filt is not None:
            filtered = filt.apply(raw_counts, valid_mask)
        else:
            filtered = raw_counts

        calibrated = calibrator.map_counts(filtered)

        msg = HandJointState()
        msg.header.stamp = rospy.Time.now()
        msg.names = list(JOINT_NAMES)
        msg.positions = calibrated
        msg.valid = [bool(valid_mask & (1 << i)) for i in range(NUM_JOINTS)]
        pub.publish(msg)

    sock.close()
    rospy.loginfo("CAN controller node stopped")


if __name__ == "__main__":
    main()
