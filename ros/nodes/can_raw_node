#!/usr/bin/env python
"""ROS node: publish raw CAN frames from SocketCAN as umi_dex/CanFrame.

No assembly, no filtering, no calibration — those happen offline
in the Python pipeline.
"""

import socket
import struct

import rospy
from umi_dex.msg import CanFrame

CAN_FRAME_FMT = "=IB3x8s"  # can_id (4), dlc (1), pad (3), data (8)
CAN_FRAME_SIZE = struct.calcsize(CAN_FRAME_FMT)


def open_can_socket(channel):
    sock = socket.socket(socket.AF_CAN, socket.SOCK_RAW, socket.CAN_RAW)
    sock.settimeout(0.1)
    sock.bind((channel,))
    return sock


def main():
    rospy.init_node("can_raw", anonymous=False)

    channel = rospy.get_param("~can_channel", "can0")
    pub = rospy.Publisher("/hand/can_raw", CanFrame, queue_size=50)

    rospy.loginfo("Opening SocketCAN on %s", channel)
    try:
        sock = open_can_socket(channel)
    except OSError as e:
        rospy.logfatal("Cannot open CAN socket on %s: %s", channel, e)
        return

    rospy.loginfo("CAN raw publisher started on %s", channel)
    while not rospy.is_shutdown():
        try:
            raw = sock.recv(CAN_FRAME_SIZE)
        except socket.timeout:
            continue
        if len(raw) < CAN_FRAME_SIZE:
            continue

        can_id, dlc, data = struct.unpack(CAN_FRAME_FMT, raw)
        arb_id = can_id & 0x1FFFFFFF

        msg = CanFrame()
        msg.header.stamp = rospy.Time.now()
        msg.arb_id = arb_id
        msg.dlc = dlc
        msg.data = list(data)
        pub.publish(msg)

    sock.close()
    rospy.loginfo("CAN raw publisher stopped")


if __name__ == "__main__":
    main()
